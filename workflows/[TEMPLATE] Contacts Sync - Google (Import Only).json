    {
      "parameters": {
        "jsCode": "const to_create = $input.first().json.to_create;\nif (!to_create.length) return [];\n\nconst contacts = to_create.map(t => ({\n  contactPerson: {\n    names: [{ givenName: t.name }],\n    emailAddresses: t.email ? [{ value: t.email }] : [],\n    phoneNumbers: t.phone ? [{ value: t.phone }] : [],\n    addresses: t.address?.fullAddress ? [{ formattedValue: t.address.fullAddress }] : [],\n    externalIds: [{ value: t.id, type: \"boligflow\" }]\n  }\n}));\n\nreturn [{ json: { contacts } }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        160,
        112
      ],
      "id": "f619a0a6-b9e8-4571-9767-c2705942ebf6",
      "name": "Byg batch: Read"
    },
    {
      "parameters": {
        "jsCode": "const tenants = $('Boligflow: Hent lejere').first().json.data.tenants.data;\nconst connections = $('Google: Hent kontakter').first().json.connections || [];\n\nconst existingIds = new Set(\n  connections\n    .flatMap(c => c.externalIds || [])\n    .filter(e => e.type === 'boligflow')\n    .map(e => e.value)\n);\n\nconst to_create = tenants.filter(t => !existingIds.has(t.id));\n\nreturn [{ json: { to_create, summary: { create: to_create.length } } }];\n"
      },
      "type": "n8n-nodes-base.code",
