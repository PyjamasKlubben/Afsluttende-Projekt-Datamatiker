    {
      "parameters": {
        "jsCode": "const BOLIGFLOW_SOURCE = 'boligflow';\n\nconst bfResp = $('Boligflow: Hent lejere').all()[0].json;\nif (bfResp.errors) throw new Error('Boligflow fejl: ' + bfResp.errors.map(e => e.message).join(', '));\nconst lejere = bfResp.data?.tenants?.data || [];\n\nconst kontakter = $('Outlook: Hent kontakter').all()[0].json.value || [];\n\nconst byBfId = {};\nfor (const k of kontakter) {\n  const note = k.personalNotes || '';\n  const match = note.match(/boligflow_id:([^\\s]+)/);\n  if (match) byBfId[match[1]] = k;\n}\n\nconst bfIds = new Set(lejere.map(l => l.id));\nconst result = [];\n\nfor (const lejer of lejere) {\n  const body = {\n    firstName: lejer.name || '',\n    lastName: '',\n    emailAddresses: lejer.email ? [lejer.email] : [],\n    mobilePhone: lejer.phone || '',\n    personalNotes: `boligflow_id:${lejer.id}\n    Adresse: ${lejer.address?.address || ''}, ${lejer.address?.zip || ''} ${lejer.address?.city || ''}`\n  };\n\n  const existing = byBfId[lejer.id];\n  if (existing) {\n    result.push({ json: { action: 'update', contactId: existing.id, body } });\n  } else {\n    result.push({ json: { action: 'create', body } });\n  }\n}\n\nfor (const [bfId, k] of Object.entries(byBfId)) {\n  if (!bfIds.has(bfId)) {\n    result.push({ json: { action: 'delete', contactId: k.id } });\n  }\n}\n\nreturn result;\n"
      },
